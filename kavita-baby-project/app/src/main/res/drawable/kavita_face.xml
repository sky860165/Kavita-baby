<!-- res/drawable/kavita_face.xml -->
<!-- Simple, cute, studious-look cartoon avatar for the floating widget. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- Background circle -->
    <path
        android:pathData="M100,100 m-100,0 a100,100 0 1,0 200,0 a100,100 0 1,0 -200,0"
        android:fillColor="#FFE3EE" />

    <!-- Hair back -->
    <path
        android:pathData="M55,70 C55,40 145,40 145,70 L150,150 C150,175 130,190 100,190 C70,190 50,175 50,150 Z"
        android:fillColor="#3D2B23" />

    <!-- Neck -->
    <path
        android:pathData="M85,120 L85,145 C85,155 115,155 115,145 L115,120 Z"
        android:fillColor="#F4C9A8" />

    <!-- Face -->
    <path
        android:pathData="M100,55 C130,55 138,80 136,105 C134,130 118,145 100,145 C82,145 66,130 64,105 C62,80 70,55 100,55 Z"
        android:fillColor="#F6D2B3" />

    <!-- Hair front / fringe -->
    <path
        android:pathData="M63,90 C60,65 75,45 100,45 C125,45 140,65 137,90 C132,80 122,72 122,72 C118,85 108,88 100,88 C92,88 82,85 78,72 C78,72 68,80 63,90 Z"
        android:fillColor="#3D2B23" />

    <!-- Left cheek blush -->
    <path
        android:pathData="M75,112 m-6,0 a6,4 0 1,0 12,0 a6,4 0 1,0 -12,0"
        android:fillColor="#F4A6A0"
        android:fillAlpha="0.6" />

    <!-- Right cheek blush -->
    <path
        android:pathData="M125,112 m-6,0 a6,4 0 1,0 12,0 a6,4 0 1,0 -12,0"
        android:fillColor="#F4A6A0"
        android:fillAlpha="0.6" />

    <!-- Smile -->
    <path
        android:pathData="M88,122 C93,128 107,128 112,122"
        android:strokeColor="#8B4A3C"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- Left eye -->
    <path
        android:pathData="M82,100 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0"
        android:fillColor="#3D2B23" />

    <!-- Right eye -->
    <path
        android:pathData="M118,100 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0"
        android:fillColor="#3D2B23" />

    <!-- Glasses: left lens -->
    <path
        android:pathData="M82,100 m-11,0 a11,11 0 1,0 22,0 a11,11 0 1,0 -22,0"
        android:strokeColor="#5B4636"
        android:strokeWidth="2.5"
        android:fillColor="#00000000" />

    <!-- Glasses: right lens -->
    <path
        android:pathData="M118,100 m-11,0 a11,11 0 1,0 22,0 a11,11 0 1,0 -22,0"
        android:strokeColor="#5B4636"
        android:strokeWidth="2.5"
        android:fillColor="#00000000" />

    <!-- Glasses: bridge -->
    <path
        android:pathData="M93,100 L107,100"
        android:strokeColor="#5B4636"
        android:strokeWidth="2.5"
        android:fillColor="#00000000" />

    <!-- Book (shoulders area, held up) -->
    <path
        android:pathData="M60,175 L100,162 L140,175 L140,195 L100,182 L60,195 Z"
        android:fillColor="#7A4FBF" />
    <path
        android:pathData="M100,162 L100,182"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:fillColor="#00000000" />

</vector>
